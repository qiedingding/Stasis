    "Prevent your Mac from sleeping while charging towards the charge limit. Sleep is re-enabled once the limit is reached or the adapter is disconnected." : {
      "localizations" : {
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ngăn máy Mac chuyển sang chế độ ngủ khi đang sạc đến mức giới hạn. Chế độ ngủ sẽ tự động kích hoạt lại khi đạt mức giới hạn hoặc khi ngắt kết nối bộ sạc."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在向充电上限充电期间阻止 Mac 进入睡眠。一旦达到上限或断开充电器，将重新启用睡眠。"
          }
        }
      }
    },
